# ── Resend (email sending) ────────────────────────────────────────────────────
# Get yours at https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address — must be from a verified domain in your Resend account.
FROM_EMAIL=Form Follows Brand <notify@formfollowsbrand.pub>

# ── Supabase (contact storage) ────────────────────────────────────────────────
# Create a project at https://supabase.com
# Settings → API → copy the Project URL and service_role key (not anon)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Site URL (used in the confirmation email) ─────────────────────────────────
SITE_URL=https://formfollowsbrand.pub
