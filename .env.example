# ── Resend (email sending) ────────────────────────────────────────────────────
# Get yours at https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address — must be from a verified domain in your Resend account.
# Go to Resend → Domains → Add domain (adaptitude.co), then add the DNS records.
FROM_EMAIL=Form Follows Brand <notify@adaptitude.co>

# ── Google Sheets (contact storage) ──────────────────────────────────────────
# 1. Go to https://console.cloud.google.com → Create a project
# 2. Enable the "Google Sheets API" for that project
# 3. IAM & Admin → Service Accounts → Create a service account
# 4. Generate a JSON key (Actions → Manage keys → Add key → JSON)
# 5. Open the JSON file — copy client_email and private_key below
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Paste the entire private key string (including -----BEGIN/END PRIVATE KEY-----)
# Vercel stores this as-is; the app converts literal \n back to real newlines.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# 6. Create a Google Sheet, share it with the service account email (Editor role)
# 7. Rename the first sheet tab to "Signups" (add headers: Email | Timestamp | Source)
# 8. Copy the Sheet ID from the URL:
#    https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
GOOGLE_SHEET_ID=1aBcDeFgHiJkLmNoPqRsTuVwXyZ

# ── Site URL (used in the confirmation email) ─────────────────────────────────
SITE_URL=https://formfollowsbrand.com
